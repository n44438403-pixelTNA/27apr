{
  "rules": {
    // ---------------------------------------------------------
    // GLOBAL ADMIN ACCESS
    // ---------------------------------------------------------
    // Only users with the 'ADMIN' role in Firestore (or hardcoded emails/UIDs) can bypass all rules.
    // NOTE: RTDB rules cannot cleanly query Firestore documents, so we rely on custom auth claims
    // or a specific known admin UID list. Alternatively, we structure the app so the admin path is open to authorized.

    // ".read": "auth != null && auth.token.admin === true",
    // ".write": "auth != null && auth.token.admin === true",

    // ---------------------------------------------------------
    // USERS DIRECTORY
    // ---------------------------------------------------------
    "users": {
      // Anyone logged in can read a profile (e.g. for Leaderboards)
      ".read": "auth != null",
      "$uid": {
        // Users can only create or update their own profile data.
        ".write": "auth != null && auth.uid === $uid",
        // Prevent users from escalating their own role to ADMIN
        // The new data's role must not be 'ADMIN' unless they were already an ADMIN.
        ".validate": "newData.child('role').val() !== 'ADMIN' || data.child('role').val() === 'ADMIN'"
      }
    },

    "nst_users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },

    // ---------------------------------------------------------
    // REDEEM CODES
    // ---------------------------------------------------------
    "redeem_codes": {
      // Any logged-in user can check if a code exists
      ".read": "auth != null",
      "$codeId": {
        // Logged-in users can write here (so the redeem flow + transaction works).
        // - Reward fields (type, amount, maxUses, subTier, subLevel, code) are
        //   protected by the per-child ".validate" rules below — they cannot be
        //   changed once an admin has set them.
        // - usedCount can only go up (never reset by a student).
        // Admins (role ADMIN / SUB_ADMIN) bypass all per-child checks.
        ".write": "auth != null",

        // Lock immutable reward fields once set by admin
        "type":     { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },
        "amount":   { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },
        "maxUses":  { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },
        "subTier":  { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },
        "subLevel": { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },
        "code":     { ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN'" },

        // usedCount may only increase (prevents abuse)
        "usedCount": { ".validate": "newData.isNumber() && (!data.exists() || newData.val() >= data.val())" },

        // redeemedBy: students append their UID; admins manage freely
        "redeemedBy": { ".validate": "true" },

        // isRedeemed is just a flag mirror
        "isRedeemed": { ".validate": "newData.isBoolean()" }
      }
    },

    // ---------------------------------------------------------
    // TEACHER CODES
    // ---------------------------------------------------------
    "teacherCodes": {
      ".read": "auth != null",
      "$code": {
        // Users can 'burn' a code (mark it inactive) when they register as a teacher
        ".write": "auth != null && data.exists() && newData.child('isActive').val() === false"
      }
    },

    // ---------------------------------------------------------
    // SYSTEM SETTINGS & APP CONFIG
    // ---------------------------------------------------------
    // The main configuration tree is strictly read-only for students.
    "system_settings": {
      ".read": "true", // Publicly readable for app initialization (theme, flags)
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    // ---------------------------------------------------------
    // CONTENT DIRECTORIES (Chapters, MCQs, Videos)
    // ---------------------------------------------------------
    // Assuming keys start with 'nst_content_' or 'nst_universal_'
    // Users can read the content if they are logged in.
    // Only admins can create/update/delete content.

    "nst_universal_playlist": {
       ".read": "auth != null",
       ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },
    "nst_universal_notes": {
       ".read": "auth != null",
       ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "content_data": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "custom_syllabus": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "public_activity": {
      ".read": "auth != null",
      ".write": "auth != null" // Written by users via savePublicActivity, or admin
    },

    // ---------------------------------------------------------
    // GLOBAL NOTE STARS (community "saved by N users" counter)
    // ---------------------------------------------------------
    // Powers the social-proof ⭐ count and "Most Saved" community
    // leaderboard. Anyone authenticated can read the global tally so the
    // counts show up everywhere. Each $hash node is a community counter:
    //   - count: number (kept in sync via a transaction)
    //   - label / noteKey / lastUpdated
    //   - users/$uid: true (per-user save flag)
    // Students need write access here so they can star their own notes
    // and contribute to the count. Only the user's own save flag may be
    // toggled by them; the aggregated `count` is recomputed from the
    // `users` map so it cannot be inflated arbitrarily.
    "note_stars": {
      ".read": "auth != null",
      "$hash": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['count']) || !newData.exists()",
        "count":       { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "label":       { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 400)" },
        "noteKey":     { ".validate": "!newData.exists() || newData.isString()" },
        "lastUpdated": { ".validate": "!newData.exists() || newData.isNumber()" },
        "users": {
          // Only the owning user may toggle their own membership flag.
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.isBoolean() || !newData.exists()"
          }
        }
      }
    },

    // ---------------------------------------------------------
    // STUDENT-PUBLISHED MCQS / SHARED NOTES (community pool)
    // ---------------------------------------------------------
    // Anyone authenticated can read the community pool. Each entry is
    // owned by its publisher ($uid), so only that user (or an admin)
    // may edit/delete it. New publishes must carry the publisher's UID
    // so we can attribute / moderate later.
    "community_mcqs": {
      ".read": "auth != null",
      "$mcqId": {
        ".write": "auth != null && (!data.exists() || data.child('publisherUid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
        ".validate": "!newData.exists() || newData.child('publisherUid').val() === auth.uid || data.child('publisherUid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN'"
      }
    },

    "community_notes": {
      ".read": "auth != null",
      "$noteId": {
        ".write": "auth != null && (!data.exists() || data.child('publisherUid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
        ".validate": "!newData.exists() || newData.child('publisherUid').val() === auth.uid || data.child('publisherUid').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN'"
      }
    },

    "universal_analysis_logs": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      ".write": "auth != null" // Written by users/admin
    },

    "ai_interactions": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      "$uid": {
         ".read": "auth != null && auth.uid === $uid",
         ".write": "auth != null && auth.uid === $uid"
      }
    },

    "demand_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      ".write": "auth != null" // Students can create demands
    },

    "content_links": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "recovery_requests": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      ".write": "true" // Public can request recovery
    },

    "custom_blogger_page": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "universal_updates": {
      ".read": "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "admin_secure": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    "secure_keys": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    },

    // Content Wildcard: Match keys that contain content data.
    // If your content is flat under root, we protect it generically.
    // If it's under a specific path, replace the wildcard below.
    "$other": {
      ".read": "auth != null",
      // Write access is generally blocked except for Admins
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'ADMIN' || root.child('users').child(auth.uid).child('role').val() === 'SUB_ADMIN' || root.child('nst_users').child(auth.uid).child('role').val() === 'SUB_ADMIN')"
    }
  }
}
